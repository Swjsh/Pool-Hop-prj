# ---- Unreal Engine generated/cache folders (never commit) ----
Binaries/
DerivedDataCache/
Intermediate/
Saved/
.vs/
.vscode/
.idea/

# Build products
*.exe
*.pdb
*.obj

# Per-user editor settings
*.opensdf
*.sdf
*.sln
*.suo
*.VC.db
*.VC.opendb

# OS junk
.DS_Store
Thumbs.db
desktop.ini

# Third-party asset staging area — raw downloads not yet imported into UE (.uasset).
# Import into Content/ThirdParty/ via the Editor first, then that gets committed instead.
_ThirdPartyStaging/

# MCP-generated local client config can contain machine-specific paths — regenerate per machine
# (uncomment if you don't want to share it across machines)
# .mcp.json

# btsc plugin debug log (local only)
.claude/btsc-debug.log
