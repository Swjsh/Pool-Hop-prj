[2026-07-01T21:32:31Z] PRE-TOOL-USE: INPUT: {"session_id":"8900910c-7bda-454a-95ef-12a1e503c884","transcript_path":"C:\\Users\\jackw\\.claude\\projects\\C--Users-jackw-Desktop-PoolHop\\8900910c-7bda-454a-95ef-12a1e503c884.jsonl","cwd":"C:\\Users\\jackw\\Desktop\\PoolHop","prompt_id":"948baa45-6f20-426f-9166-3cc47a65e9cf","permission_mode":"bypassPermissions","effort":{"level":"max"},"hook_event_name":"PreToolUse","tool_name":"Write","tool_input":{"file_path":"C:\\Users\\jackw\\AppData\\Local\\Temp\\claude\\C--Users-jackw-Desktop-PoolHop\\8900910c-7bda-454a-95ef-12a1e503c884\\scratchpad\\InputProbe.ps1","content":"# InputProbe.ps1 — launch PoolHop standalone, inject real OS-level input (SendInput), capture window screenshots.\n# PS 5.1 compatible. All artifacts go to the scratchpad dir passed as -OutDir.\nparam(\n    [string]$OutDir = \"$PSScriptRoot\",\n    [int]$BootTimeoutSec = 150\n)\n\n$ErrorActionPreference = 'Stop'\nAdd-Type -AssemblyName System.Drawing\nAdd-Type -AssemblyName System.Windows.Forms\n\nAdd-Type -TypeDefinition @\"\nusing System;\nusing System.Text;\nusing System.Collections.Generic;\nusing System.Runtime.InteropServices;\n\npublic class Probe {\n    [DllImport(\"user32.dll\")] public static extern bool SetProcessDPIAware();\n    [DllImport(\"user32.dll\")] public static extern bool EnumWindows(EnumWindowsProc cb, IntPtr lParam);\n    public delegate bool EnumWindowsProc(IntPtr hWnd, IntPtr lParam);\n    [DllImport(\"user32.dll\")] public static extern int GetWindowTextLength(IntPtr hWnd);\n    [DllImport(\"user32.dll\")] public static extern int GetWindowText(IntPtr hWnd, StringBuilder sb, int max);\n    [DllImport(\"user32.dll\")] public static extern bool IsWindowVisible(IntPtr hWnd);\n    [DllImport(\"user32.dll\")] public static extern uint GetWindowThreadProcessId(IntPtr hWnd, out uint pid);\n    [DllImport(\"user32.dll\")] public static extern bool GetWindowRect(IntPtr hWnd, out RECT rect);\n    [DllImport(\"user32.dll\")] public static extern bool SetForegroundWindow(IntPtr hWnd);\n    [DllImport(\"user32.dll\")] public static extern IntPtr GetForegroundWindow();\n    [DllImport(\"user32.dll\")] public static extern bool SetCursorPos(int x, int y);\n    [DllImport(\"user32.dll\")] public static extern uint SendInput(uint n, INPUT[] inputs, int size);\n    [DllImport(\"user32.dll\")] public static extern uint MapVirtualKey(uint uCode, uint uMapType);\n\n    [StructLayout(LayoutKind.Sequential)] public struct RECT { public int L, T, R, B; }\n\n    [StructLayout(LayoutKind.Sequential)] public struct INPUT { public uint type; public InputUnion U; }\n    [StructLayout(LayoutKind.Explicit)] public struct InputUnion {\n        [FieldOffset(0)] public MOUSEINPUT mi;\n        [FieldOffset(0)] public KEYBDINPUT ki;\n    }\n    [StructLayout(LayoutKind.Sequential)] public struct MOUSEINPUT { public int dx, dy; public uint mouseData, dwFlags, time; public IntPtr extra; }\n    [StructLayout(LayoutKind.Sequential)] public struct KEYBDINPUT { public ushort vk, scan; public uint flags, time; public IntPtr extra; }\n\n    public const uint INPUT_MOUSE = 0, INPUT_KEYBOARD = 1;\n    public const uint KEYEVENTF_KEYUP = 2, KEYEVENTF_SCANCODE = 8;\n    public const uint MOUSEEVENTF_MOVE = 1, MOUSEEVENTF_LEFTDOWN = 2, MOUSEEVENTF_LEFTUP = 4;\n\n    public static void Key(ushort vk, bool up) {\n        INPUT[] inp = new INPUT[1];\n        inp[0].type = INPUT_KEYBOARD;\n        inp[0].U.ki.vk = vk;\n        inp[0].U.ki.scan = (ushort)MapVirtualKey(vk, 0);\n        inp[0].U.ki.flags = up ? KEYEVENTF_KEYUP : 0;\n        SendInput(1, inp, Marshal.SizeOf(typeof(INPUT)));\n    }\n    // scancode-only variant (some engines read scancodes)\n    public static void KeySc(ushort vk, bool up) {\n        INPUT[] inp = new INPUT[1];\n        inp[0].type = INPUT_KEYBOARD;\n        inp[0].U.ki.vk = 0;\n        inp[0].U.ki.scan = (ushort)MapVirtualKey(vk, 0);\n        inp[0].U.ki.flags = KEYEVENTF_SCANCODE | (up ? KEYEVENTF_KEYUP : 0);\n        SendInput(1, inp, Marshal.SizeOf(typeof(INPUT)));\n    }\n    public static void MouseBtn(bool up) {\n        INPUT[] inp = new INPUT[1];\n        inp[0].type = INPUT_MOUSE;\n        inp[0].U.mi.dwFlags = up ? MOUSEEVENTF_LEFTUP : MOUSEEVENTF_LEFTDOWN;\n        SendInput(1, inp, Marshal.SizeOf(typeof(INPUT)));\n    }\n    public static void MouseMoveRel(int dx, int dy) {\n        INPUT[] inp = new INPUT[1];\n        inp[0].type = INPUT_MOUSE;\n        inp[0].U.mi.dx = dx; inp[0].U.mi.dy = dy;\n        inp[0].U.mi.dwFlags = MOUSEEVENTF_MOVE;\n        SendInput(1, inp, Marshal.SizeOf(typeof(INPUT)));\n    }\n\n    public class WinInfo { public IntPtr H; public uint Pid; public string Title; public RECT R; }\n    public static List<WinInfo> Windows() {\n        List<WinInfo> list = new List<WinInfo>();\n        EnumWindows(delegate(IntPtr h, IntPtr l) {\n            if (!IsWindowVisible(h)) return true;\n            int len = GetWindowTextLength(h);\n            if (len == 0) return true;\n            StringBuilder sb = new StringBuilder(len + 1);\n            GetWindowText(h, sb, sb.Capacity);\n            uint pid; GetWindowThreadProcessId(h, out pid);\n            RECT r; GetWindowRect(h, out r);\n            WinInfo w = new WinInfo(); w.H = h; w.Pid = pid; w.Title = sb.ToString(); w.R = r;\n            list.Add(w);\n            return true;\n        }, IntPtr.Zero);\n        return list;\n    }\n}\n\"@\n\n[void][Probe]::SetProcessDPIAware()\n\nfunction Capture-Rect([int]$x, [int]$y, [int]$w, [int]$h, [string]$path) {\n    $bmp = New-Object System.Drawing.Bitmap($w, $h)\n    $g = [System.Drawing.Graphics]::FromImage($bmp)\n    $g.CopyFromScreen($x, $y, 0, 0, (New-Object System.Drawing.Size($w, $h)))\n    $g.Dispose()\n    $bmp.Save($path, [System.Drawing.Imaging.ImageFormat]::Png)\n    $bmp.Dispose()\n}\n\n# ---------- 1. Launch standalone game ----------\n$ue = \"C:\\Program Files\\Epic Games\\UE_5.8\\Engine\\Binaries\\Win64\\UnrealEditor.exe\"\n$proj = \"C:\\Users\\jackw\\Desktop\\PoolHop\\PoolHop.uproject\"\n$args_ = @($proj, \"-game\", \"-windowed\", \"-ResX=1280\", \"-ResY=720\", \"-WinX=80\", \"-WinY=80\", \"-NoSplash\")\nWrite-Output \"LAUNCH: standalone -game\"\n$p = Start-Process -FilePath $ue -ArgumentList $args_ -PassThru\nWrite-Output (\"PID: {0}\" -f $p.Id)\n\n# ---------- 2. Wait for the game window (belongs to our PID, decent size) ----------\n$gameWin = $null\n$deadline = (Get-Date).AddSeconds($BootTimeoutSec)\nwhile ((Get-Date) -lt $deadline) {\n    Start-Sleep -Milliseconds 2000\n    if ($p.HasExited) { Write-Output (\"GAME PROCESS EXITED early, code={0}\" -f $p.ExitCode); break }\n    $wins = [Probe]::Windows() | Where-Object { $_.Pid -eq $p.Id }\n    foreach ($w in $wins) {\n        $ww = $w.R.R - $w.R.L; $wh = $w.R.B - $w.R.T\n        if ($ww -gt 800 -and $wh -gt 500) { $gameWin = $w; break }\n    }\n    if ($gameWin) { break }\n}\nif (-not $gameWin) {\n    Write-Output \"NO GAME WINDOW FOUND. All visible windows:\"\n    [Probe]::Windows() | ForEach-Object { Write-Output (\"  pid={0} '{1}' rect=({2},{3},{4},{5})\" -f $_.Pid, $_.Title, $_.R.L, $_.R.T, $_.R.R, $_.R.B) }\n    exit 1\n}\n$L = $gameWin.R.L; $T = $gameWin.R.T; $W = $gameWin.R.R - $L; $H = $gameWin.R.B - $T\nWrite-Output (\"GAME WINDOW: '{0}' rect=({1},{2}) {3}x{4}\" -f $gameWin.Title, $L, $T, $W, $H)\n\n# Let the map + BeginPlay settle\nStart-Sleep -Seconds 8\nif ($p.HasExited) { Write-Output \"GAME EXITED during settle.\"; exit 1 }\n\n# ---------- 3. Baseline screenshot ----------\nCapture-Rect $L $T $W $H (Join-Path $OutDir \"1_before.png\")\nWrite-Output \"SHOT: 1_before.png\"\n\n# ---------- 4. Click into the window (real mouse) ----------\n$cx = $L + [int]($W / 2); $cy = $T + [int]($H / 2)\n[void][Probe]::SetForegroundWindow($gameWin.H)\nStart-Sleep -Milliseconds 300\n[void][Probe]::SetCursorPos($cx, $cy)\nStart-Sleep -Milliseconds 200\n[Probe]::MouseBtn($false); Start-Sleep -Milliseconds 60; [Probe]::MouseBtn($true)\nStart-Sleep -Milliseconds 500\n$fg = [Probe]::GetForegroundWindow()\nWrite-Output (\"FOREGROUND after click: {0} (game={1}, match={2})\" -f $fg, $gameWin.H, ($fg -eq $gameWin.H))\n\n# ---------- 5. Hold W for 1.5 s (VK 0x57), capture mid-hold ----------\n[Probe]::Key(0x57, $false)\nStart-Sleep -Milliseconds 700\nCapture-Rect $L $T $W $H (Join-Path $OutDir \"2_during_W.png\")\nStart-Sleep -Milliseconds 800\n[Probe]::Key(0x57, $true)\nStart-Sleep -Milliseconds 400\nCapture-Rect $L $T $W $H (Join-Path $OutDir \"3_after_W.png\")\nWrite-Output \"SHOT: 2_during_W.png, 3_after_W.png (W held 1.5s)\"\n\n# ---------- 6. Mouse-look: relative move right in steps ----------\nfor ($i = 0; $i -lt 10; $i++) { [Probe]::MouseMoveRel(60, 0); Start-Sleep -Milliseconds 25 }\nStart-Sleep -Milliseconds 400\nCapture-Rect $L $T $W $H (Join-Path $OutDir \"4_after_look.png\")\nWrite-Output \"SHOT: 4_after_look.png (mouse +600px right)\"\n\n# ---------- 7. Jump (Space VK 0x20), capture near apex ----------\n[Probe]::Key(0x20, $false); Start-Sleep -Milliseconds 80; [Probe]::Key(0x20, $true)\nStart-Sleep -Milliseconds 350\nCapture-Rect $L $T $W $H (Join-Path $OutDir \"5_jump.png\")\nWrite-Output \"SHOT: 5_jump.png (Space, captured 350ms after press)\"\n\n# ---------- 8. Done — leave the game running for possible follow-up, report ----------\nWrite-Output (\"GAME STILL RUNNING: {0}\" -f (-not $p.HasExited))\nWrite-Output \"DONE\"\n"},"tool_use_id":"toolu_01WNvZGW2gEcf9vnq8VovXFb"}
